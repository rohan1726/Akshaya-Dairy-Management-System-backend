# MongoDB (required for backend)
# Get connection string from MongoDB Atlas: https://cloud.mongodb.com
# Format: mongodb+srv://USERNAME:PASSWORD@CLUSTER.mongodb.net/DATABASE?retryWrites=true&w=majority
MONGODB_URI=mongodb+srv://YOUR_USER:YOUR_PASSWORD@YOUR_CLUSTER.mongodb.net/akshaya_dairy?retryWrites=true&w=majority

# JWT for auth (set a long random string in production)
JWT_SECRET=your-jwt-secret-change-in-production

# Optional (for landing page links; set in Vercel so Admin/Driver links work)
ADMIN_APP_URL=https://your-admin-project.vercel.app
DRIVER_APP_URL=https://your-driver-project.vercel.app

# Optional
NODE_ENV=development
PORT=3000
